  subgraph THRESHOLDS["Per-Class DEEP_THRESHOLDS (routing.py:23-54)"]
    direction TB
    T1["Reentrancy: 0.35 | IntegerUO: 0.35"]
    T2["GasException: 0.40 | Timestamp: 0.35"]
    T3["TransactionOrderDependence: 0.35"]
    T4["ExternalBug: 0.40 | CallToUnknown: 0.40"]
    T5["MishandledException: 0.40"]
    T6["UnusedReturn: 0.45 | DenialOfService: 0.30"]
  end

  subgraph MLRESULT["ml_result 3-Tier Schema (state.py:55-74)"]
    direction TB
    LABEL["label: safe | suspicious | confirmed_vulnerable"]
    PROBS["probabilities: dict[str, float]
full 10-class vector"]
    CONF["confirmed: list[dict]
prob ≥ 0.55"]
    SUSP["suspicious: list[dict]
0.25 ≤ prob < 0.55"]
    META["tier_thresholds, thresholds
truncated, windows_used
num_nodes, num_edges"]
  end

  subgraph VERDICT["Verdict Computation — 3 Algorithms"]
    direction TB
    subgraph ALGO1["A.1 Rule-based (routing.py:187)"]
      direction TB
      RV1["prob ≥ 0.50 + slither_match → CONFIRMED"]
      RV2["prob ≥ 0.50 + rag≥0.80 → CONFIRMED"]
      RV3["prob ≥ 0.50 + rag≥0.50 → LIKELY"]
      RV4["prob ≥ 0.50 alone → DISPUTED"]
      RV5["fast path → LIKELY"]
    end
    subgraph ALGO2["A.4 LLM Debate (cross_validator)"]
      direction TB
      PROS["① Prosecutor
argues VULNERABLE"]
      DEF["② Defender
argues FALSE POSITIVE"]
      JUDGE["③ Judge
renders JSON verdict"]
      PROS --> DEF --> JUDGE
    end
    subgraph ALGO3["A.6/A.7 Consensus (consensus_engine)"]
      direction TB
      CV["weighted vote:
ML (×0.5) + Slither + Aderyn"]
      CI["Key invariant:
ML alone NEVER → CONFIRMED"]
    end
  end


  subgraph ROLES["The 4 Model Roles"]
    direction TB

    subgraph FAST["MODEL_FAST — gemma-4-e2b-it (2B)"]
      FA["Speed: ~12 tok/s on RTX 3070 (3.18 GB VRAM)
Used by: cross_validator debate (A.4)
  reflection optional LLM (A.3)
  consensus_engine LLM assist (A.6)
Default: temperature=0.0"]
    end

    subgraph STRONG["MODEL_STRONG — gemma-4-e2b-it (2B) ← was qwen3.5-9B"]
      ST["Speed: ~17-30s per task (was 23min for 9B!)
Used by: synthesizer narrative
  RAG synthesis, report generation
FIX-18 (2026-06-17): swapped from qwen3.5-9b-ud
  (2.91 tok/s → 23min for 4096 tok)
⚠ BOTH FAST and STRONG now point to same model"]
    end

    subgraph CODER["MODEL_CODER — qwen2.5-coder-7b-instruct"]
      CO["Used by: Solidity analysis, code logic review
  cross_validator debate when reading source
Understands: access control, state machines
  reentrancy patterns, upgrade proxies"]
    end

    subgraph EMBED["MODEL_EMBED — nomic-embed-text-v1.5"]
      EM["Used by: RAG index building + query embedding
Output: 768-dim vectors
Note: OpenAIEmbeddings() not ChatOpenAI()
Why text embed not code embed:
  we embed natural language descriptions, not Solidity"]
    end
  end

  subgraph FACTORY["Factory Pattern (client.py:75-108)"]
    direction TB
    GEN["get_llm(model, temperature=0.0, max_tokens=None)
→ ChatOpenAI(base_url=LM_STUDIO_BASE_URL,
              api_key=LM_STUDIO_API_KEY,
              timeout=LM_STUDIO_TIMEOUT)"]
    F1["get_fast_llm() → get_llm(MODEL_FAST)"]
    F2["get_strong_llm(max_tokens) → get_llm(MODEL_STRONG, max_tokens)"]
    F3["get_coder_llm() → get_llm(MODEL_CODER)"]
    F4["get_embedding_model() → OpenAIEmbeddings(model=MODEL_EMBED)"]
    GEN --> F1
    GEN --> F2
    GEN --> F3
    GEN --> F4
  end

